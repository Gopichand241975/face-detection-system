# Copy this to .env and fill in real values for production

# PostgreSQL
POSTGRES_USER=facedet
POSTGRES_PASSWORD=facedet
POSTGRES_DB=facedetdb

# Backend
DATABASE_URL=postgresql+asyncpg://facedet:facedet@db:5432/facedetdb
SECRET_KEY=change-me-in-production
CORS_ORIGINS=["http://localhost:3000"]

# Frontend build args
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000
